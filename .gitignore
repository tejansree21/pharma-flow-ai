# ─────────────────────────────────────────────────────────────────────────────
# PharmaFlow AI — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.production
*.key
*.pem
*.p12

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
ENV/
env/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
bandit-report.json
bandit-report.txt

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Node / Dashboard ──────────────────────────────────────────────────────────
dashboard/node_modules/
dashboard/dist/
dashboard/.env
dashboard/.env.local

# ── Generated Data ────────────────────────────────────────────────────────────
# CSVs committed for deployment (Render/Railway startup needs them)
# Re-generate locally with: python startup.py
# Uncomment below to exclude from git (use DVC for large datasets):
# data/synthetic/*.csv
# data/processed/*.csv

# ── Trained Models ────────────────────────────────────────────────────────────
# PKL files are committed for deployment (generated by startup.py)
# Uncomment below to exclude for DVC / model registry workflows:
# models/**/*.pkl
# models/**/*.joblib

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep compose files tracked
# docker-compose.override.yml  ← override for local dev

# ── Monitoring data ───────────────────────────────────────────────────────────
prometheus-data/
grafana-data/
