# ─────────────────────────────────────────────────────────────────────────────
# PharmaFlow AI — Environment Configuration
# Copy to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# API key for external callers (dashboard, CI, etc.)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change_me_to_a_secure_api_key

# JWT settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60        # requests per minute per IP (0 = disabled)

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (* for all)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Data Paths ────────────────────────────────────────────────────────────────
DATA_DIR=data
MODELS_DIR=models

# ── External APIs (Phase 5 live connectors) ───────────────────────────────────
# NewsAPI — https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_ENABLED=false

# GDELT Project (free, no key needed)
GDELT_ENABLED=false

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics

# ── Dashboard ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
